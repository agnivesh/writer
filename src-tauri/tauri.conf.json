{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Writer",
  "version": "0.1.0",
  "identifier": "com.agni.writer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Writer",
        "width": 1440,
        "height": 920,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity"
  }
}
